# Build the tokenswim-gateway binary for linux/amd64 (Cloudflare Containers).
FROM golang:1.26-bookworm AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags="-s -w" -o /out/tokenswim-gateway ./cmd/tokenswim-gateway

FROM gcr.io/distroless/static-debian12:nonroot
COPY --from=build /out/tokenswim-gateway /tokenswim-gateway
EXPOSE 8787
ENTRYPOINT ["/tokenswim-gateway"]
